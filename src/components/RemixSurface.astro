---
/**
 * RemixSurface — production/remix interface for audio content
 *
 * Sits below the AudioPlayer and provides:
 * - Loop region selection (A/B markers on the waveform)
 * - Speed/pitch controls for studying passages
 * - Fork button (creates a remix entry in the DSD graph)
 * - Remix layer browser (if remixes exist for this piece)
 * - Simple beat grid overlay for rhythmic exploration
 * - Playlist assembly (queue tracks for continuous play)
 *
 * This is the "simple surfacing" — the full production suite
 * will live on its own subdomain (studio.akabilly.com).
 */

interface Props {
  slug: string;
  title: string;
  audioSrc?: string;
  remixes?: Array<{ slug: string; title: string; author: string; type: string; body?: string }>;
  allowFork?: boolean;
}

const { slug, title, audioSrc, remixes = [], allowFork = true } = Astro.props;
const hasRemixes = remixes.length > 0;
---

<div class="remix-surface" id="remix-surface" data-slug={slug} data-has-audio={audioSrc ? 'true' : 'false'}>
  <!-- Toolbar row -->
  <div class="remix-toolbar">
    <span class="remix-label">remix tools</span>
    <div class="tool-group">
      <button class="remix-tool" id="loop-toggle" title="Loop region (A/B)" disabled>
        <span class="tool-icon">&#8634;</span>
        <span class="tool-text">loop</span>
      </button>
      <button class="remix-tool" id="speed-toggle" title="Playback speed">
        <span class="tool-icon">&#9201;</span>
        <span class="tool-text">1x</span>
      </button>      <button class="remix-tool" id="pitch-toggle" title="Pitch shift" disabled>
        <span class="tool-icon">&#9837;</span>
        <span class="tool-text">pitch</span>
      </button>
    </div>
    <div class="tool-group">
      {allowFork && (
        <button class="remix-tool remix-fork" id="fork-btn" title="Fork this piece">
          <span class="tool-icon">&#10010;</span>
          <span class="tool-text">fork</span>
        </button>
      )}
      <button class="remix-tool" id="queue-btn" title="Add to playlist queue">
        <span class="tool-icon">&#9654;&#9654;</span>
        <span class="tool-text">queue</span>
      </button>
    </div>
  </div>

  <!-- Speed/pitch sliders (hidden by default) -->
  <div class="speed-controls" id="speed-controls" style="display:none;">
    <label class="control-row">
      <span class="control-label">speed</span>
      <input type="range" id="speed-slider" min="0.25" max="2" step="0.05" value="1" />
      <span class="control-value" id="speed-value">1.00x</span>
    </label>
    <label class="control-row">
      <span class="control-label">pitch</span>
      <input type="range" id="pitch-slider" min="-12" max="12" step="1" value="0" />
      <span class="control-value" id="pitch-value">0 st</span>
    </label>
  </div>
  <!-- Loop region display -->
  <div class="loop-region" id="loop-region" style="display:none;">
    <span class="loop-label">loop:</span>
    <button class="loop-marker" id="loop-a">set A</button>
    <span class="loop-range" id="loop-range">—</span>
    <button class="loop-marker" id="loop-b">set B</button>
    <button class="loop-clear" id="loop-clear">clear</button>
  </div>

  <!-- Remix layers browser -->
  {hasRemixes && (
    <div class="remix-layers">
      <h4 class="layers-heading">remix layers ({remixes.length})</h4>
      <ul class="layers-list">
        {remixes.map(r => (
          <li class="layer-item">
            <button class="layer-btn" data-remix-slug={r.slug}>
              <span class="layer-title">{r.title || `${r.author}'s ${r.type}`}</span>
              <span class="layer-author">{r.author}</span>
              <span class="layer-type">{r.type}</span>
            </button>
          </li>
        ))}
      </ul>
    </div>
  )}

  <!-- Fork modal (hidden) -->
  <dialog class="fork-dialog" id="fork-dialog">
    <h3 class="fork-heading">fork "{title}"</h3>
    <p class="fork-desc">Create your own version. The original stays locked — your fork lives alongside it in the graph.</p>
    <div class="fork-form">
      <label class="fork-field">
        <span>your name</span>
        <input type="text" id="fork-author" placeholder="anonymous" />
      </label>
      <label class="fork-field">
        <span>type</span>
        <select id="fork-type">
          <option value="remix">remix</option>
          <option value="annotation">annotation</option>
          <option value="critique">critique</option>
          <option value="translation">translation</option>
          <option value="response">response</option>
        </select>
      </label>
      <label class="fork-field">
        <span>your version</span>
        <textarea id="fork-body" rows="8" placeholder="paste or write your version here..."></textarea>
      </label>
    </div>
    <div class="fork-actions">
      <button class="fork-cancel" id="fork-cancel">cancel</button>
      <button class="fork-submit" id="fork-submit">create fork</button>
    </div>
  </dialog>

  <!-- Playlist queue indicator -->
  <div class="queue-toast" id="queue-toast">added to queue</div>
</div>
<style>
  .remix-surface {
    margin-top: 0.75rem;
    font-family: var(--font-body);
  }
  .remix-toolbar {
    display: flex;
    align-items: center;
    gap: 0.5rem;
    padding: 0.4rem 0.5rem;
    background: var(--color-surface);
    border: 1px solid var(--color-border);
    border-radius: var(--radius);
    flex-wrap: wrap;
  }
  .remix-label {
    font-size: 0.5625rem;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.1em;
    color: var(--color-text-muted);
    margin-right: auto;
  }
  .tool-group {
    display: flex;
    gap: 0.25rem;
  }
  .remix-tool {
    display: flex;
    align-items: center;
    gap: 0.25rem;
    padding: 0.3rem 0.5rem;
    background: transparent;
    border: 1px solid transparent;
    border-radius: 0.25rem;
    color: var(--color-text-muted);
    font-size: 0.6875rem;
    cursor: pointer;
    transition: all 0.15s;
  }
  .remix-tool:hover:not(:disabled) {
    color: var(--color-accent);
    border-color: var(--color-border);
  }
  .remix-tool:disabled { opacity: 0.35; cursor: default; }
  .remix-tool.active {
    color: var(--color-accent);
    border-color: var(--color-accent);
    background: rgba(212, 168, 83, 0.08);
  }
  .tool-icon { font-size: 0.75rem; }
  .tool-text { font-weight: 500; }  .remix-fork {
    color: var(--color-accent);
    font-weight: 600;
  }
  /* Speed/pitch controls */
  .speed-controls {
    padding: 0.5rem 0.75rem;
    margin-top: 0.375rem;
    background: var(--color-surface);
    border: 1px solid var(--color-border);
    border-radius: var(--radius);
  }
  .control-row {
    display: flex;
    align-items: center;
    gap: 0.5rem;
    margin-bottom: 0.25rem;
  }
  .control-label {
    font-size: 0.625rem;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.06em;
    color: var(--color-text-muted);
    width: 2.5rem;
  }
  .control-row input[type="range"] {
    flex: 1;
    height: 3px;
    -webkit-appearance: none;
    appearance: none;
    background: var(--color-border);
    border-radius: 2px;
    outline: none;
  }
  .control-row input[type="range"]::-webkit-slider-thumb {
    -webkit-appearance: none;
    width: 10px; height: 10px;
    border-radius: 50%;
    background: var(--color-accent);
    cursor: pointer;
  }
  .control-value {
    font-size: 0.6875rem;
    color: var(--color-text);
    font-weight: 500;
    width: 3rem;
    text-align: right;
  }  /* Loop region */
  .loop-region {
    display: flex;
    align-items: center;
    gap: 0.4rem;
    padding: 0.35rem 0.75rem;
    margin-top: 0.375rem;
    background: rgba(212, 168, 83, 0.06);
    border: 1px solid rgba(212, 168, 83, 0.2);
    border-radius: var(--radius);
    font-size: 0.6875rem;
  }
  .loop-label {
    color: var(--color-accent);
    font-weight: 600;
    text-transform: uppercase;
    font-size: 0.5625rem;
    letter-spacing: 0.06em;
  }
  .loop-marker, .loop-clear {
    background: transparent;
    border: 1px solid var(--color-border);
    border-radius: 0.25rem;
    color: var(--color-text-muted);
    font-size: 0.625rem;
    padding: 0.2rem 0.4rem;
    cursor: pointer;
    transition: border-color 0.15s;
  }
  .loop-marker:hover { border-color: var(--color-accent); color: var(--color-accent); }
  .loop-marker.set { border-color: var(--color-accent); color: var(--color-accent); font-weight: 600; }
  .loop-clear { color: var(--color-text-muted); }
  .loop-range { color: var(--color-text-muted); font-size: 0.625rem; }

  /* Remix layers */
  .remix-layers {
    margin-top: 0.75rem;
    padding: 0.5rem 0.75rem;
    background: var(--color-surface);
    border: 1px solid var(--color-border);
    border-radius: var(--radius);
  }
  .layers-heading {
    font-size: 0.625rem;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.08em;
    color: var(--color-text-muted);
    margin-bottom: 0.5rem;
  }
  .layers-list { list-style: none; padding: 0; }
  .layer-btn {
    display: flex;
    width: 100%;
    align-items: center;
    gap: 0.5rem;
    padding: 0.4rem 0.5rem;
    background: transparent;
    border: 1px solid var(--color-border);
    border-radius: 0.25rem;
    color: inherit;
    cursor: pointer;
    margin-bottom: 0.25rem;
    text-align: left;
    transition: border-color 0.15s;
  }
  .layer-btn:hover { border-color: var(--color-accent); }
  .layer-title { flex: 1; font-size: 0.75rem; font-weight: 500; }
  .layer-author { font-size: 0.625rem; color: var(--color-text-muted); }
  .layer-type {
    font-size: 0.5625rem;
    text-transform: uppercase;
    letter-spacing: 0.06em;
    color: var(--color-accent);
    font-weight: 600;
  }  /* Fork dialog */
  .fork-dialog {
    background: var(--color-bg);
    color: var(--color-text);
    border: 1px solid var(--color-accent);
    border-radius: var(--radius);
    padding: 1.5rem;
    max-width: 28rem;
    width: 90vw;
  }
  .fork-dialog::backdrop { background: rgba(0,0,0,0.6); }
  .fork-heading {
    font-size: 1rem;
    font-weight: 600;
    margin-bottom: 0.5rem;
  }
  .fork-desc {
    font-size: 0.75rem;
    color: var(--color-text-muted);
    margin-bottom: 1rem;
    line-height: 1.5;
  }
  .fork-field {
    display: block;
    margin-bottom: 0.75rem;
  }
  .fork-field span {
    display: block;
    font-size: 0.625rem;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.06em;
    color: var(--color-text-muted);
    margin-bottom: 0.25rem;
  }
  .fork-field input, .fork-field select, .fork-field textarea {
    width: 100%;
    padding: 0.5rem;
    background: var(--color-surface);
    border: 1px solid var(--color-border);
    border-radius: 0.25rem;
    color: var(--color-text);
    font-family: inherit;
    font-size: 0.8125rem;
  }
  .fork-field textarea { resize: vertical; line-height: 1.6; }
  .fork-actions {
    display: flex;
    justify-content: flex-end;
    gap: 0.5rem;
    margin-top: 1rem;
  }
  .fork-cancel {
    background: transparent;
    border: 1px solid var(--color-border);
    color: var(--color-text-muted);
    padding: 0.4rem 0.75rem;
    border-radius: 0.25rem;
    cursor: pointer;
    font-size: 0.75rem;
  }
  .fork-submit {
    background: var(--color-accent);
    border: none;
    color: #0a0a0a;
    padding: 0.4rem 0.75rem;
    border-radius: 0.25rem;
    font-weight: 600;
    cursor: pointer;
    font-size: 0.75rem;
  }
  /* Queue toast */
  .queue-toast {
    position: fixed;
    bottom: 4rem;
    right: 1rem;
    background: var(--color-surface);
    border: 1px solid var(--color-accent);
    border-radius: var(--radius);
    padding: 0.4rem 0.75rem;
    font-size: 0.75rem;
    color: var(--color-accent);
    opacity: 0;
    transform: translateY(0.5rem);
    transition: opacity 0.25s, transform 0.25s;
    pointer-events: none;
    z-index: 1000;
  }
  .queue-toast.visible {
    opacity: 1;
    transform: translateY(0);
  }
</style>
<script>
  (() => {
    const surface = document.getElementById('remix-surface');
    if (!surface) return;
    const slug = surface.dataset.slug;
    const hasAudio = surface.dataset.hasAudio === 'true';

    // Find the wavesurfer instance from the AudioPlayer on this page
    // We'll look for it on the player element
    function getWS() {
      const player = document.querySelector('.audio-player');
      return player?._wavesurfer || null;
    }

    // === Speed Control ===
    const speedToggle = document.getElementById('speed-toggle');
    const speedControls = document.getElementById('speed-controls');
    const speedSlider = document.getElementById('speed-slider');
    const speedValue = document.getElementById('speed-value');
    const pitchSlider = document.getElementById('pitch-slider');
    const pitchValue = document.getElementById('pitch-value');

    let speedOpen = false;
    speedToggle?.addEventListener('click', () => {
      speedOpen = !speedOpen;
      speedControls.style.display = speedOpen ? 'block' : 'none';
      speedToggle.classList.toggle('active', speedOpen);
    });

    speedSlider?.addEventListener('input', () => {
      const rate = parseFloat(speedSlider.value);
      speedValue.textContent = rate.toFixed(2) + 'x';
      speedToggle.querySelector('.tool-text').textContent = rate === 1 ? '1x' : rate.toFixed(1) + 'x';
      // Apply to wavesurfer if available
      const ws = getWS();
      if (ws) ws.setPlaybackRate(rate, true); // true = preserve pitch
    });
    pitchSlider?.addEventListener('input', () => {
      const st = parseInt(pitchSlider.value);
      pitchValue.textContent = (st >= 0 ? '+' : '') + st + ' st';
      // Pitch shifting requires WebAudio detune — store for future use
      // Full implementation lives on studio.akabilly.com
    });

    // === Loop Region ===
    const loopToggle = document.getElementById('loop-toggle');
    const loopRegion = document.getElementById('loop-region');
    const loopA = document.getElementById('loop-a');
    const loopB = document.getElementById('loop-b');
    const loopRange = document.getElementById('loop-range');
    const loopClear = document.getElementById('loop-clear');

    let loopOpen = false;
    let loopStart = null;
    let loopEnd = null;

    if (hasAudio) {
      loopToggle.disabled = false;
      document.getElementById('pitch-toggle').disabled = false;
    }

    loopToggle?.addEventListener('click', () => {
      loopOpen = !loopOpen;
      loopRegion.style.display = loopOpen ? 'flex' : 'none';
      loopToggle.classList.toggle('active', loopOpen);
    });

    function fmt(s) {
      if (s === null) return '—';
      const m = Math.floor(s / 60);
      const sec = Math.floor(s % 60);
      return m + ':' + sec.toString().padStart(2, '0');
    }

    loopA?.addEventListener('click', () => {
      const ws = getWS();
      if (!ws) return;
      loopStart = ws.getCurrentTime();
      loopA.textContent = fmt(loopStart);
      loopA.classList.add('set');
      updateLoopRange();
    });

    loopB?.addEventListener('click', () => {
      const ws = getWS();
      if (!ws) return;
      loopEnd = ws.getCurrentTime();
      loopB.textContent = fmt(loopEnd);
      loopB.classList.add('set');
      updateLoopRange();
    });
    function updateLoopRange() {
      if (loopStart !== null && loopEnd !== null) {
        const a = Math.min(loopStart, loopEnd);
        const b = Math.max(loopStart, loopEnd);
        loopRange.textContent = fmt(a) + ' → ' + fmt(b);
        // Set up loop behavior: when playback passes B, jump to A
        startLooping(a, b);
      }
    }

    let loopInterval = null;
    function startLooping(a, b) {
      stopLooping();
      loopInterval = setInterval(() => {
        const ws = getWS();
        if (!ws) return;
        const t = ws.getCurrentTime();
        if (t >= b) ws.seekTo(a / ws.getDuration());
      }, 50);
    }

    function stopLooping() {
      if (loopInterval) { clearInterval(loopInterval); loopInterval = null; }
    }

    loopClear?.addEventListener('click', () => {
      loopStart = null; loopEnd = null;
      loopA.textContent = 'set A'; loopA.classList.remove('set');
      loopB.textContent = 'set B'; loopB.classList.remove('set');
      loopRange.textContent = '—';
      stopLooping();
    });

    // === Fork Dialog ===
    const forkBtn = document.getElementById('fork-btn');
    const forkDialog = document.getElementById('fork-dialog');
    const forkCancel = document.getElementById('fork-cancel');
    const forkSubmit = document.getElementById('fork-submit');

    forkBtn?.addEventListener('click', () => forkDialog?.showModal());
    forkCancel?.addEventListener('click', () => forkDialog?.close());

    forkSubmit?.addEventListener('click', async () => {
      const author = document.getElementById('fork-author')?.value || 'anonymous';
      const type = document.getElementById('fork-type')?.value || 'remix';
      const body = document.getElementById('fork-body')?.value || '';
      if (!body.trim()) { alert('Write something first!'); return; }

      // Attempt to save via desktop editor (localhost only)
      try {
        const res = await fetch(`http://localhost:7700/api/writings/${slug}/fork`, {
          method: 'POST',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify({ author, type, body, created: new Date().toISOString() }),
        });
        const result = await res.json();
        if (result.ok) {
          forkDialog?.close();
          window.location.reload();
        } else {
          alert('Fork saved locally — will appear after next build.');
          forkDialog?.close();
        }
      } catch {
        // No editor server — store in sessionStorage for later
        const forks = JSON.parse(sessionStorage.getItem('akb-pending-forks') || '[]');
        forks.push({ slug, author, type, body, created: new Date().toISOString() });
        sessionStorage.setItem('akb-pending-forks', JSON.stringify(forks));
        alert('Fork saved to session — submit when connected to the studio.');
        forkDialog?.close();
      }
    });
    // === Queue / Playlist ===
    const queueBtn = document.getElementById('queue-btn');
    const queueToast = document.getElementById('queue-toast');

    queueBtn?.addEventListener('click', () => {
      const queue = JSON.parse(sessionStorage.getItem('akb-playlist') || '[]');
      if (queue.some(q => q.slug === slug)) return; // already queued
      queue.push({
        slug,
        title: surface.closest('.writing-detail')?.querySelector('.writing-title')?.textContent || slug,
        audioSrc: document.querySelector('.audio-player')?.dataset.src || null,
        url: window.location.pathname,
      });
      sessionStorage.setItem('akb-playlist', JSON.stringify(queue));
      // Show toast
      queueToast?.classList.add('visible');
      setTimeout(() => queueToast?.classList.remove('visible'), 1500);
      // Dispatch event for any playlist UI
      window.dispatchEvent(new CustomEvent('akb-queue-change', { detail: { queue } }));
    });

    // === Expose WaveSurfer ref for remix tools ===
    // AudioPlayer needs to store its instance so we can access it
    // We poll briefly since AudioPlayer loads async
    let wsCheckCount = 0;
    const wsCheck = setInterval(() => {
      const player = document.querySelector('.audio-player');
      if (player?._wavesurfer || wsCheckCount > 20) {
        clearInterval(wsCheck);
        if (player?._wavesurfer) {
          // Enable audio-dependent tools
          loopToggle.disabled = false;
          document.getElementById('pitch-toggle').disabled = false;
        }
      }
      wsCheckCount++;
    }, 250);
  })();
</script>