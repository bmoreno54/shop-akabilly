---
import Base from '../../layouts/Base.astro';
import AudioPlayer from '../../components/AudioPlayer.astro';
import RemixSurface from '../../components/RemixSurface.astro';
import DSDConnections from '../../components/DSDConnections.astro';
import CommentThread from '../../components/CommentThread.astro';
import NavigationMode from '../../components/NavigationMode.astro';
import SiteNav from '../../components/SiteNav.astro';

const writingModules = import.meta.glob('../../data/writings/*.json', { eager: true });
const allWritings = Object.values(writingModules).map((m: any) => m.default);

export function getStaticPaths() {
  const modules = import.meta.glob('../../data/writings/*.json', { eager: true });
  const writings = Object.values(modules).map((m: any) => m.default);
  return writings.map(w => ({ params: { slug: w.slug }, props: { writing: w } }));
}

const { writing } = Astro.props;
const lines = writing.body.split('\n');
const remixes = writing.remixes || [];
const remixJSON = JSON.stringify(remixes);

const typeLabels: Record<string, string> = {
  lyrics: 'Lyrics',
  essay: 'Essay',
  note: 'Note',
  fragment: 'Fragment',
};
---

<Base title={`${writing.title} — ${typeLabels[writing.type] || writing.type}`} description={writing.description}>
  <article class="writing-detail container">
    <header class="writing-header">
      <span class="writing-type-badge">{typeLabels[writing.type] || writing.type}</span>
      <h1 class="writing-title">{writing.title}</h1>
      <p class="writing-meta">{writing.artist} · {writing.year}</p>
    </header>

    {writing.audioSrc && (
      <div class="writing-player">
        <AudioPlayer src={writing.audioSrc} title={writing.title} />
        <RemixSurface
          slug={writing.slug}
          title={writing.title}
          audioSrc={writing.audioSrc}
          remixes={remixes}
          allowFork={true}
        />
      </div>
    )}

    {remixes.length > 0 && (
      <nav class="remix-bar" id="remix-bar">
        <button class="remix-tab active" data-remix="original">original</button>
        {remixes.map((r: any) => (
          <button class="remix-tab" data-remix={r.slug}>
            {r.title || `${r.author}'s ${r.type || 'remix'}`}
          </button>
        ))}
      </nav>
    )}

    <div class="writing-body" id="writing-body" data-slug={writing.slug} data-remixes={remixJSON}>
      {lines.map((line: string, i: number) => (
        line.trim() === '' ? <br /> : (
          <p class="writing-line" id={`L${i + 1}`} data-line={i + 1}>
            <a class="line-anchor" href={`#L${i + 1}`} aria-label={`Line ${i + 1}`}>{i + 1}</a>
            <span class="line-text">{line}</span>
          </p>
        )
      ))}
    </div>

    <CommentThread nodeId={writing.slug} nodeTitle={writing.title} lineAddressable={true} />

    <footer class="writing-footer">
      <div class="provenance">
        <p class="author-lock">Original text by {writing.artist}. All rights reserved.</p>
        <p class="remix-note">Fork it, remix it, annotate it, quote it — just don't edit the source.</p>
      </div>
    </footer>
  </article>

  <SiteNav showScrollNav={false}>
    <Fragment slot="panel-left">
      <h3 class="panel-heading">connections</h3>
      <DSDConnections nodeId={writing.slug} limit={12} tags={writing.tags || []} nodeType="writing" />
    </Fragment>
    <Fragment slot="panel-right">
      <h3 class="panel-heading">about this piece</h3>
      <dl class="writing-meta-panel">
        <dt>type</dt>
        <dd>{typeLabels[writing.type] || writing.type}</dd>
        <dt>artist</dt>
        <dd>{writing.artist}</dd>
        <dt>year</dt>
        <dd>{writing.year}</dd>
      </dl>
      <a href="/writings" class="back-link">all writings</a>
    </Fragment>
  </SiteNav>
</Base>

<style>
  .writing-detail {
    padding: 3rem 1.5rem;
    max-width: 36rem;
    margin: 0 auto;
  }
  .writing-header { margin-bottom: 2rem; }
  .writing-type-badge {
    font-size: 0.6875rem;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.08em;
    color: var(--color-accent);
  }
  .writing-title {
    font-size: 2rem;
    font-weight: 700;
    margin: 0.25rem 0 0.5rem;
    letter-spacing: -0.02em;
  }
  .writing-meta {
    font-size: 0.8125rem;
    color: var(--color-text-muted);
  }
  .writing-player { margin-bottom: 2rem; }
  .writing-body {
    font-size: 1rem;
    line-height: 1.7;
    margin-bottom: 3rem;
  }
  .writing-line {
    margin: 0;
    padding: 0.1rem 0;
  }
  .writing-footer {
    border-top: 1px solid var(--color-border);
    padding-top: 1.5rem;
  }
  .author-lock {
    font-size: 0.75rem;
    font-weight: 600;
    color: var(--color-text-muted);
    margin-bottom: 0.25rem;
  }
  .remix-note {
    font-size: 0.75rem;
    color: var(--color-text-muted);
    font-style: italic;
    margin-bottom: 1rem;
  }
  .paired-link {
    display: inline-block;
    font-size: 0.8125rem;
    color: var(--color-accent);
    text-decoration: none;
    transition: opacity 0.2s;
  }
  .paired-link:hover { opacity: 0.8; }

  /* remix layer bar */
  .remix-bar {
    display: flex;
    gap: 0.25rem;
    margin-bottom: 1.5rem;
    padding: 0.25rem;
    background: var(--color-surface);
    border-radius: var(--radius);
    border: 1px solid var(--color-border);
  }
  .remix-tab {
    padding: 0.4rem 0.75rem;
    background: transparent;
    border: none;
    border-radius: calc(var(--radius) * 0.75);
    color: var(--color-text-muted);
    font-size: 0.75rem;
    font-weight: 500;
    cursor: pointer;
    transition: background 0.15s, color 0.15s;
  }
  .remix-tab:hover { color: var(--color-text); }
  .remix-tab.active {
    background: var(--color-bg);
    color: var(--color-accent);
    font-weight: 600;
  }

  /* author edit mode */
  .author-edit-bar {
    display: flex;
    align-items: center;
    gap: 0.75rem;
    padding: 0.5rem 0.75rem;
    margin-bottom: 1.5rem;
    background: rgba(212, 168, 83, 0.08);
    border: 1px solid rgba(212, 168, 83, 0.25);
    border-radius: var(--radius);
    font-size: 0.75rem;
    color: var(--color-accent);
  }
  .author-edit-bar button {
    background: var(--color-accent);
    color: #0a0a0a;
    border: none;
    border-radius: var(--radius);
    padding: 0.35rem 0.75rem;
    font-size: 0.75rem;
    font-weight: 600;
    cursor: pointer;
  }
  .author-edit-bar .edit-label {
    flex: 1;
  }

  /* panel content styles */
  .panel-heading {
    font-size: 0.75rem;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.08em;
    color: var(--color-accent);
    margin-bottom: 1rem;
  }
  .writing-meta-panel {
    font-size: 0.8125rem;
    line-height: 1.6;
  }
  .writing-meta-panel dt {
    color: var(--color-text-muted);
    font-size: 0.6875rem;
    text-transform: uppercase;
    letter-spacing: 0.06em;
    margin-top: 0.75rem;
  }
  .writing-meta-panel dd {
    color: var(--color-text);
    margin-left: 0;
  }
  .back-link {
    display: inline-block;
    margin-top: 1.5rem;
    font-size: 0.8125rem;
    color: var(--color-accent);
  }
  .back-link:hover { color: var(--color-accent-hover); }

  /* line-level addressability */
  .writing-line {
    position: relative;
    display: flex;
    gap: 0;
    align-items: baseline;
  }
  .line-anchor {
    position: absolute;
    left: -2.5rem;
    width: 2rem;
    text-align: right;
    font-size: 0.625rem;
    font-family: var(--font-body);
    color: transparent;
    text-decoration: none;
    user-select: none;
    transition: color 0.15s;
    line-height: inherit;
    padding-top: 0.1rem;
  }
  .writing-line:hover .line-anchor,
  .writing-line.quoted .line-anchor {
    color: var(--color-text-muted);
  }
  .writing-line.quoted {
    background: rgba(212, 168, 83, 0.08);
    border-left: 2px solid var(--color-accent);
    margin-left: -0.75rem;
    padding-left: 0.75rem;
    border-radius: 0 2px 2px 0;
  }
  .line-text {
    flex: 1;
  }
  .quote-toast {
    position: fixed;
    bottom: 4rem;
    left: 50%;
    transform: translateX(-50%) translateY(1rem);
    background: var(--color-surface);
    border: 1px solid var(--color-accent);
    border-radius: var(--radius);
    padding: 0.5rem 1rem;
    font-size: 0.8125rem;
    color: var(--color-accent);
    opacity: 0;
    pointer-events: none;
    transition: opacity 0.25s, transform 0.25s;
    z-index: 1000;
  }
  .quote-toast.visible {
    opacity: 1;
    transform: translateX(-50%) translateY(0);
    pointer-events: auto;
  }
  .quote-toast button {
    background: none;
    border: none;
    color: var(--color-accent);
    cursor: pointer;
    font-weight: 600;
    margin-left: 0.5rem;
    text-decoration: underline;
  }
</style>


<script>
  // Line-level quote system
  // Click line number: highlight + update URL
  // Shift-click: range selection
  // Copy link from toast notification
  (() => {
    const body = document.getElementById('writing-body');
    if (!body) return;
    const slug = body.dataset.slug;

    // Create toast
    const toast = document.createElement('div');
    toast.className = 'quote-toast';
    toast.innerHTML = '<span class="toast-text"></span><button class="copy-link-btn">copy link</button>';
    document.body.appendChild(toast);
    const toastText = toast.querySelector('.toast-text');
    const copyBtn = toast.querySelector('.copy-link-btn');

    let lastClicked = null;
    let toastTimer = null;

    function clearQuotes() {
      body.querySelectorAll('.writing-line.quoted').forEach(el => el.classList.remove('quoted'));
    }

    function highlightRange(start, end) {
      clearQuotes();
      const from = Math.min(start, end);
      const to = Math.max(start, end);
      for (let i = from; i <= to; i++) {
        const line = document.getElementById('L' + i);
        if (line) line.classList.add('quoted');
      }
      // Update URL
      const frag = from === to ? 'L' + from : 'L' + from + '-L' + to;
      history.replaceState(null, '', '#' + frag);
      // Show toast
      const count = to - from + 1;
      toastText.textContent = count === 1 ? 'line ' + from + ' selected' : 'lines ' + from + '-' + to + ' selected';
      toast.classList.add('visible');
      clearTimeout(toastTimer);
      toastTimer = setTimeout(() => toast.classList.remove('visible'), 4000);
    }

    // Line anchor clicks
    body.addEventListener('click', (e) => {
      const anchor = e.target.closest('.line-anchor');
      if (!anchor) return;
      e.preventDefault();
      const line = anchor.closest('.writing-line');
      const num = parseInt(line.dataset.line);

      if (e.shiftKey && lastClicked !== null) {
        highlightRange(lastClicked, num);
      } else {
        highlightRange(num, num);
        lastClicked = num;
      }
    });

    // Copy link button
    copyBtn.addEventListener('click', () => {
      const url = window.location.href;
      navigator.clipboard.writeText(url).then(() => {
        toastText.textContent = 'link copied';
        setTimeout(() => toast.classList.remove('visible'), 1500);
      });
    });

    // Handle initial hash (line or range)
    function parseHash() {
      const hash = window.location.hash.slice(1);
      if (!hash) return;
      // Single line: #L5
      const single = hash.match(/^L(\d+)$/);
      if (single) {
        const n = parseInt(single[1]);
        highlightRange(n, n);
        document.getElementById('L' + n)?.scrollIntoView({ behavior: 'smooth', block: 'center' });
        return;
      }
      // Range: #L3-L7
      const range = hash.match(/^L(\d+)-L(\d+)$/);
      if (range) {
        const from = parseInt(range[1]);
        const to = parseInt(range[2]);
        highlightRange(from, to);
        document.getElementById('L' + from)?.scrollIntoView({ behavior: 'smooth', block: 'center' });
      }
    }
    parseHash();
    window.addEventListener('hashchange', parseHash);
  })();
</script>

<script>
  // Remix layer switching
  // Reads hash fragment, swaps body content to matching remix
  // Supports: /writings/lode-lyrics#brandisremix
  (() => {
    const body = document.getElementById('writing-body');
    if (!body) return;
    const remixes = JSON.parse(body.dataset.remixes || '[]');
    if (!remixes.length) return;

    // Store original content for switching back
    const originalHTML = body.innerHTML;

    function renderLines(text) {
      return text.split('\n').map(line =>
        line.trim() === '' ? '<br>' : `<p class="writing-line">${line}</p>`
      ).join('');
    }

    function switchTo(remixSlug) {
      const tabs = document.querySelectorAll('.remix-tab');
      tabs.forEach(t => t.classList.toggle('active', t.dataset.remix === remixSlug));

      if (remixSlug === 'original') {
        body.innerHTML = originalHTML;
        // Update provenance display
        const lock = document.querySelector('.author-lock');
        if (lock) lock.textContent = `Original text by ${body.closest('.writing-detail')?.querySelector('.writing-meta')?.textContent?.split('·')[0]?.trim() || 'akabilly'}. All rights reserved.`;
        return;
      }

      const remix = remixes.find(r => r.slug === remixSlug);
      if (!remix) return;
      body.innerHTML = renderLines(remix.body);

      // Update provenance to show remix attribution
      const lock = document.querySelector('.author-lock');
      if (lock) lock.textContent = `${remix.type || 'Remix'} by ${remix.author} · ${remix.created}`;
    }

    // Tab click handling
    document.querySelectorAll('.remix-tab').forEach(tab => {
      tab.addEventListener('click', () => {
        const slug = tab.dataset.remix;
        switchTo(slug);
        history.replaceState(null, '', slug === 'original' ? window.location.pathname : `#${slug}`);
      });
    });

    // Handle initial hash
    const hash = window.location.hash.slice(1);
    if (hash && remixes.find(r => r.slug === hash)) {
      switchTo(hash);
    }

    // Handle hash changes (back/forward)
    window.addEventListener('hashchange', () => {
      const h = window.location.hash.slice(1);
      switchTo(h || 'original');
    });
  })();

  // Author edit mode — only active on localhost
  if (window.location.hostname === 'localhost' || window.location.hostname === '127.0.0.1') {
    const body = document.getElementById('writing-body');
    const slug = body?.dataset.slug;
    if (body && slug) {
      const bar = document.createElement('div');
      bar.className = 'author-edit-bar';
      bar.innerHTML = `
        <span class="edit-label">author mode</span>
        <button id="edit-writing-btn">edit</button>
        <button id="save-writing-btn" style="display:none">save to vault</button>
        <button id="cancel-edit-btn" style="display:none">cancel</button>
      `;
      body.parentElement?.insertBefore(bar, body);

      const editBtn = document.getElementById('edit-writing-btn');
      const saveBtn = document.getElementById('save-writing-btn');
      const cancelBtn = document.getElementById('cancel-edit-btn');
      let originalHTML = '';

      editBtn?.addEventListener('click', () => {
        // Switch to editable textarea
        originalHTML = body.innerHTML;
        const lines = Array.from(body.querySelectorAll('.writing-line'))
          .map(el => el.textContent || '');
        const text = lines.join('\n');
        body.innerHTML = `<textarea id="writing-editor" style="
          width:100%; min-height:20rem; background:var(--color-bg);
          color:var(--color-text); border:1px solid var(--color-border);
          border-radius:var(--radius); padding:1rem; font-family:inherit;
          font-size:1rem; line-height:1.7; resize:vertical;
        ">${text}</textarea>`;
        editBtn.style.display = 'none';
        saveBtn!.style.display = '';
        cancelBtn!.style.display = '';
      });

      cancelBtn?.addEventListener('click', () => {
        body.innerHTML = originalHTML;
        editBtn!.style.display = '';
        saveBtn!.style.display = 'none';
        cancelBtn!.style.display = 'none';
      });

      saveBtn?.addEventListener('click', async () => {
        const editor = document.getElementById('writing-editor') as HTMLTextAreaElement;
        if (!editor) return;
        const newText = editor.value;
        try {
          const res = await fetch(`http://localhost:7700/api/writings/${slug}`, {
            method: 'PUT',
            headers: { 'Content-Type': 'application/json' },
            body: JSON.stringify({ body: newText }),
          });
          const result = await res.json();
          if (result.ok) {
            // Refresh to show updated content
            window.location.reload();
          } else {
            alert('Save failed: ' + (result.error || 'unknown error'));
          }
        } catch (err) {
          alert('Could not reach desktop editor at localhost:7700. Is it running?');
        }
      });
    }
  }
</script>
